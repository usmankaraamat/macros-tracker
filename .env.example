# Copy this file to `.env` and paste your real keys there.
# `.env` is gitignored and never committed. `.env.example` (this file) is safe to commit — it holds no secrets.
#
# USDA FoodData Central key:  https://fdc.nal.usda.gov/api-key-signup.html
# Gemini API key:             https://aistudio.google.com/apikey

USDA_API_KEY=your_usda_key_here
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
